# claude-proxy docker-compose environment

# Host interface to bind to. 127.0.0.1 keeps the proxy loopback-only (recommended
# for the PoC: there is no downstream auth between Claude Code and the proxy).
# Set to 0.0.0.0 to expose to the LAN — only do this on a trusted network.
HOST_BIND=127.0.0.1

# Host port mapped to the container's :8787.
HOST_PORT=8787

# UID/GID the container process runs as. Must own ./data and ./creds on the host.
# Default 1000:1000 matches the typical first-user-on-Linux setup. Override with:
#   PROXY_UID=$(id -u)  PROXY_GID=$(id -g)
PROXY_UID=1000
PROXY_GID=1000

# Logging
#   level:  debug | info | warn | error
#   format: auto | pretty | text | json
#     auto   — pretty on a tty, json otherwise (recommended for `make logs`-style use)
#     pretty — colorized one-line-per-event, per-credential color highlighting
#     text   — slog stdlib text handler
#     json   — slog stdlib json handler (ideal for log shippers under docker)
#   color:  auto | always | never
#     auto   — on whenever the active format is "pretty" (recommended)
#     always — force ANSI colors even into pipes/files (useful for `docker logs`)
#     never  — disable colors entirely
LOG_LEVEL=info
LOG_FORMAT=auto
LOG_COLOR=auto

# Shared bearer token Claude Code must send to authenticate to the proxy.
# Generate with:  openssl rand -hex 32
# Empty/unset = no downstream auth (loopback only — anyone who can reach the
# proxy can spend your subscription quota). STRONGLY recommended whenever the
# proxy is reachable beyond loopback (HOST_BIND=0.0.0.0, LAN, tailscale, etc.).
PROXY_AUTH_TOKEN=

# ----------------------------------------------------------------------------
# Optional: Traefik HTTPS termination with Let's Encrypt
# ----------------------------------------------------------------------------
# Set TLS_DOMAIN to a fully-qualified domain that resolves to this host's
# public IP. Leaving it empty disables Traefik entirely (proxy stays plain
# HTTP on HOST_PORT). When set, `make up` automatically activates the `tls`
# compose profile, runs Traefik on :80 / :443, and obtains a Let's Encrypt
# certificate via the TLS-ALPN-01 challenge.
#
# Requirements when TLS_DOMAIN is set:
#   • DNS A/AAAA record for TLS_DOMAIN points at this host
#   • Ports 80 and 443 reachable from the public internet
#   • TLS_EMAIL is a real address (Let's Encrypt sends expiry warnings here)
#   • You almost certainly want HOST_BIND=127.0.0.1 (or remove HOST_PORT
#     entirely) so the plain-HTTP listener is not exposed alongside HTTPS
TLS_DOMAIN=
TLS_EMAIL=

# Use the Let's Encrypt STAGING endpoint while you debug DNS / firewall. The
# staging CA issues untrusted-but-functional certs and has far higher rate
# limits. Switch back to production once curl -v https://$TLS_DOMAIN works.
#   staging:    https://acme-staging-v02.api.letsencrypt.org/directory
#   production: https://acme-v02.api.letsencrypt.org/directory   (default)
TLS_CASERVER=https://acme-v02.api.letsencrypt.org/directory

# Traefik log level: DEBUG | INFO | WARN | ERROR
TRAEFIK_LOG_LEVEL=INFO
